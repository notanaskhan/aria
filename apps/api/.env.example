# Database
DATABASE_URL=postgresql+asyncpg://aria:password@localhost:5432/aria
DATABASE_SYNC_URL=postgresql://aria:password@localhost:5432/aria

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1

# Auth (Clerk)
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_WEBHOOK_SECRET=whsec_...

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_GROWTH=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# LLM
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Encryption (for channel credentials)
ENCRYPTION_KEY=your-32-byte-base64-encoded-key

# ChromaDB
CHROMA_HOST=localhost
CHROMA_PORT=8001

# Sentry
SENTRY_DSN=https://...@sentry.io/...

# PostHog
POSTHOG_API_KEY=phc_...

# App
APP_ENV=development
APP_SECRET_KEY=your-secret-key-here
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
API_PREFIX=/api/v1

# Slack Bot
SLACK_SIGNING_SECRET=...

# WhatsApp
WHATSAPP_VERIFY_TOKEN=aria-webhook-verify
